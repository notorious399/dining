#include <iostream>
#include <thread>
#include <vector>
#include <mutex>

std::mutex forks[5];

void philosopher(int id) {
    int first = id;
    int second = (id + 1) % 5;

    // Solution: The last philosopher picks up forks in reverse order
    if (id == 4) std::swap(first, second);

    while (true) {
        std::cout << "Philosopher " << id << " is thinking.\n";
        
        std::lock_guard<std::mutex> lock1(forks[first]);
        std::lock_guard<std::mutex> lock2(forks[second]);

        std::cout << "Philosopher " << id << " is eating.\n";
        std::this_thread::sleep_for(std::chrono::milliseconds(500));
    }
}

int main() {
    std::vector<std::thread> philosophers;
    for (int i = 0; i < 5; ++i)
        philosophers.emplace_back(philosopher, i);

    for (auto& t : philosophers) t.join();
    return 0;
}
